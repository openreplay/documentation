---
import { VERSIONS } from '~/config';
const latest = VERSIONS[0];
---

<div class="dh-ver" id="or-version">
	<button type="button" class="dh-ver-btn" id="or-version-btn" aria-haspopup="listbox" aria-expanded="false">
		<span class="dh-ver-dot" aria-hidden="true"></span>
		<span class="dh-ver-lbl" id="or-version-lbl">v{latest.title}</span>
		<span class="dh-ver-sub" id="or-version-sub">latest</span>
		<span class="dh-ver-car" aria-hidden="true">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"></path></svg>
		</span>
	</button>
	<div class="dh-ver-menu" id="or-version-menu" role="listbox" hidden>
		{
			VERSIONS.map((v, i) => (
				<button type="button" class="dh-ver-item" data-url={v.url} data-version={v.title} role="option">
					<span>v{v.title}</span>
					{i === 0 && <span class="dh-ver-tag">latest</span>}
				</button>
			))
		}
	</div>
</div>

<script is:inline>
	(() => {
		const root = document.getElementById('or-version');
		if (!root) return;
		const btn = document.getElementById('or-version-btn');
		const menu = document.getElementById('or-version-menu');
		const lbl = document.getElementById('or-version-lbl');
		const sub = document.getElementById('or-version-sub');

		// Detect current version from the URL (segment after /lang/).
		const seg = window.location.pathname.split('/')[2] || '';
		const current = seg.indexOf('v') === 0 ? seg : '';
		if (current) {
			lbl.textContent = 'v' + current.replace('v', '');
			sub.textContent = '';
		}

		// Mark the selected version.
		menu.querySelectorAll('.dh-ver-item').forEach((it) => {
			const url = (it.getAttribute('data-url') || '').replace('/', '');
			const isSel = url === current || (!current && url === '');
			it.classList.toggle('sel', isSel);
		});

		const close = () => {
			menu.hidden = true;
			btn.classList.remove('open');
			btn.setAttribute('aria-expanded', 'false');
		};
		btn.addEventListener('click', (e) => {
			e.stopPropagation();
			const willOpen = menu.hidden;
			menu.hidden = !willOpen;
			btn.classList.toggle('open', willOpen);
			btn.setAttribute('aria-expanded', String(willOpen));
		});
		document.addEventListener('click', (e) => {
			if (!root.contains(e.target)) close();
		});

		menu.querySelectorAll('.dh-ver-item').forEach((it) => {
			it.addEventListener('click', () => {
				const selectedVersion = it.getAttribute('data-url') || '';
				const versionRegExp = /v[0-9]+\.[0-9]+\.[0-9]+/;
				let pathname = window.location.pathname.replace(/\/$/, '');
				let pathParts = pathname.split('/');
				if (pathname.match(versionRegExp)) {
					pathParts[2] = selectedVersion.replace('/', '');
				} else {
					pathParts = [pathParts[0], pathParts[1], selectedVersion.replace('/', ''), ...pathParts.slice(2)];
				}
				const newPath =
					window.location.protocol +
					'//' +
					window.location.host +
					pathParts.join('/').replace('//', '/');
				window.location.href = newPath;
			});
		});
	})();
</script>
