---
import * as icons from 'lucide-astro';

export interface Props {
	href?: string;
	icon?: string;
	title: string;
	desc?: string;
}

const { href, icon, title, desc } = Astro.props as Props;
const Icon = icon && (icons as any)[icon] ? (icons as any)[icon] : null;
const Tag = href ? 'a' : 'div';
---

<Tag class="or-row" {...(href ? { href } : {})}>
	{Icon && (
		<span class="or-row-ico"><Icon size={17} stroke-width={1.8} /></span>
	)}
	<span class="or-row-tx">
		<b>{title}</b>
		{desc && <span>{desc}</span>}
	</span>
	<span class="or-row-arr" aria-hidden="true">→</span>
</Tag>
