---
import * as icons from 'lucide-astro';

export interface Props {
	href?: string;
	icon?: string;
}

const { href, icon } = Astro.props as Props;
const Icon = icon && (icons as any)[icon] ? (icons as any)[icon] : null;
const Tag = href ? 'a' : 'span';
---

<Tag class="or-chip" {...(href ? { href } : {})}>
	{Icon && <Icon size={15} stroke-width={1.8} />}
	<slot />
</Tag>
