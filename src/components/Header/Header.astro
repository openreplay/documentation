---
import SkipToContent from './SkipToContent.astro';
import SidebarToggle from './SidebarToggle';
import LanguageSelect from './LanguageSelect';
import ThemeToggleButton from './ThemeToggleButton';
import { getLanguageFromURL } from '../../util';
import { useTranslations, getDocSearchStrings } from '../../i18n/util';
import ORLogo from './ORLogo.astro';
import AiChatBot from '../AiChatBot/AiChatBot';
import Search from '../Header/Search.astro';

const { currentPage } = Astro.props;
const lang = (currentPage && getLanguageFromURL(currentPage)) || 'en';
const t = useTranslations(Astro);
const docsearchStrings = getDocSearchStrings(Astro);
---

<header>
	<SkipToContent />
	<Search labels={docsearchStrings} lang={lang} />

	<nav class="nav-wrapper" aria-label={t('navbar.a11yTitle')}>
		<!-- Logo + DOCS badge -->
		<div class="brand">
			<a class="logo-clickarea" href={`/${lang || 'en'}/home`}>
				<ORLogo />
				<span class="sr-only">OpenReplay</span>
			</a>
			<span class="docs-badge dp-mono">DOCS</span>
		</div>

		<div class="spacer"></div>

		<!-- Search pill (desktop) -->
		<button
			type="button"
			class="search-pill hide-sm"
			aria-label="Search documentation"
			onclick="window.dispatchEvent(new Event('open-docsearch'))"
		>
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3-3"></path></svg>
			<span class="search-pill-label">{docsearchStrings.placeholder || 'Search documentation'}</span>
			<span class="search-kbd dp-mono">⌘K</span>
		</button>

		<div class="divider hide-sm"></div>

		<!-- GitHub stars pill (desktop) -->
		<a
			href="https://github.com/openreplay/openreplay"
			target="_blank"
			rel="noreferrer"
			class="hdr-pill github-pill hide-sm"
			aria-label="OpenReplay on GitHub"
		>
			<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"></path></svg>
			<span class="dp-mono" id="gh-star-count">24.8k</span>
		</a>

		<!-- Language pill (desktop) -->
		<div class="hide-sm" dir="ltr" lang="en">
			{lang && <LanguageSelect lang={lang} client:idle />}
		</div>

		<!-- Theme toggle pill (desktop) -->
		<div class="nav-theme-toggle hide-sm">
			<ThemeToggleButton
				client:visible
				labels={{
					useLight: t('themeToggle.useLight') || 'Light mode',
					useDark: t('themeToggle.useDark') || 'Dark mode',
				}}
				isInsideHeader={true}
			/>
		</div>

		<!-- Try Cloud CTA (desktop) -->
		<a href="https://app.openreplay.com/signup" target="_blank" rel="noreferrer" class="try-cloud hide-sm">Try Cloud</a>

		<!-- Mobile: search icon + burger -->
		<SidebarToggle client:idle />
	</nav>

	<AiChatBot client:load />
</header>

<script is:inline>
	(function () {
		var el = document.getElementById('gh-star-count');
		if (!el) return;
		var fmt = function (n) {
			return n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : String(n);
		};
		try {
			var cached = localStorage.getItem('or_gh_stars');
			var at = +localStorage.getItem('or_gh_stars_at') || 0;
			if (cached && Date.now() - at < 86400000) { el.textContent = fmt(+cached); return; }
		} catch (e) {}
		fetch('https://api.github.com/repos/openreplay/openreplay')
			.then(function (r) { return r.ok ? r.json() : null; })
			.then(function (d) {
				if (d && d.stargazers_count) {
					el.textContent = fmt(d.stargazers_count);
					try {
						localStorage.setItem('or_gh_stars', d.stargazers_count);
						localStorage.setItem('or_gh_stars_at', Date.now());
					} catch (e) {}
				}
			})
			.catch(function () {});
	})();
</script>

<style>
	header {
		position: fixed;
		left: 0;
		top: 0;
		right: 0;
		z-index: 9999;
		padding: 0 22px;
		background-color: var(--header-bg);
		-webkit-backdrop-filter: blur(10px);
		backdrop-filter: blur(10px);
		display: flex;
		align-items: center;
		border-bottom: 1px solid var(--or-border);
		height: var(--theme-navbar-height);
	}

	.nav-wrapper {
		display: flex;
		align-items: center;
		gap: 8px;
		width: 100%;
	}

	.spacer { flex: 1; }

	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		flex: none;
	}
	.logo-clickarea { display: block; line-height: 1; text-decoration: none; }
	.brand :global(svg.w-36) { height: 21px; width: auto; display: block; }
	.docs-badge {
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.04em;
		color: var(--text-3);
		padding: 3px 8px;
		border: 1px solid var(--or-border);
		border-radius: 6px;
		line-height: 1;
	}

	/* search pill */
	.search-pill {
		display: flex;
		align-items: center;
		gap: 8px;
		height: 36px;
		padding: 0 14px;
		min-width: 280px;
		border: 1px solid var(--or-border);
		border-radius: 9999px;
		background: var(--surface);
		color: var(--text-3);
		cursor: pointer;
		font-family: var(--fb);
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.search-pill:hover { border-color: var(--accent-ring); box-shadow: var(--shadow-md); }
	.search-pill-label { font-size: 13.5px; flex: 1; text-align: left; }
	.search-kbd {
		font-size: 11px;
		padding: 2px 8px;
		border: 1px solid var(--or-border);
		border-radius: 9999px;
	}

	.divider { width: 1px; height: 24px; background: var(--or-border); flex: none; }

	/* utility pills (github) */
	.hdr-pill {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		height: 34px;
		padding: 0 13px;
		border-radius: 9999px;
		background: var(--surface);
		border: 1px solid var(--or-border);
		color: var(--text-2);
		text-decoration: none;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.hdr-pill:hover { border-color: var(--accent-ring); box-shadow: var(--shadow-md); }
	.hdr-pill { flex: none; white-space: nowrap; }
	.github-pill span { font-size: 12px; white-space: nowrap; }

	/* Try Cloud */
	.try-cloud {
		height: 34px;
		display: inline-flex;
		align-items: center;
		padding: 0 16px;
		border-radius: 9999px;
		background: var(--accent);
		color: #fff;
		font-size: 13px;
		font-weight: 600;
		text-decoration: none;
		flex: none;
		transition: background 0.2s ease, box-shadow 0.2s ease;
	}
	.try-cloud:hover { background: var(--accent-press); box-shadow: var(--shadow-md); color: #fff; }

	/* show/hide helpers (≤768px = mobile) */
	.hide-sm { display: inline-flex; }
	@media (max-width: 768px) {
		header { padding: 0 14px; }
		.nav-wrapper { gap: 8px; }
		.hide-sm { display: none !important; }
	}
	/* hide native sidebar/search islands appropriately handled inside SidebarToggle */
</style>
