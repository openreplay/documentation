---
import TableOfContents from './TableOfContents';
import { useTranslations } from '../../i18n/util';

const t = useTranslations(Astro);
const { content, githubEditUrl } = Astro.props;
const headings = Astro.props.headings;
const editHref = githubEditUrl;
---

<nav class="or-toc-nav" aria-label={t('rightSidebar.a11yTitle')}>
	{
		headings && (
			<TableOfContents
				client:media="(min-width: 64em)"
				headings={headings}
				labels={{ onThisPage: t('rightSidebar.onThisPage') || 'On this page', overview: t('rightSidebar.overview') || 'Overview' }}
				isMobile={false}
			/>
		)
	}

	<div class="or-toc-actions">
		<a class="or-toc-act" aria-label="Back to top" href="#top" onclick="document.getElementById('or-main-scroll')?.scrollTo({top:0,behavior:'smooth'});return false;">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"></path></svg>
		</a>
		{
			editHref && (
				<a class="or-toc-act" aria-label="Edit on GitHub" href={editHref} target="_blank" rel="noreferrer">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
				</a>
			)
		}
	</div>
</nav>
