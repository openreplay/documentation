---
import { useTranslations } from '../i18n/util';
export interface Props {
	type?: 'note' | 'tip' | 'caution' | 'danger' | 'ai';
	title?: string;
}

const t = useTranslations(Astro);
const { type = 'note', title = t(`aside.${type}`) } = Astro.props as Props;
---

<aside class={`or-aside or-${type}`} aria-label={title}>
	<p class="or-aside-label" aria-hidden="true">
		<span class="icon">
			{type === 'tip' && (
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1h6c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2Z"></path>
				</svg>
			)}
			{type === 'note' && (
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="9"></circle><path d="M12 11v5M12 8h.01"></path>
				</svg>
			)}
			{type === 'caution' && (
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M10.3 3.9 2 18a2 2 0 0 0 1.7 3h16.6A2 2 0 0 0 22 18L13.7 3.9a2 2 0 0 0-3.4 0Z"></path><path d="M12 9v4M12 17h.01"></path>
				</svg>
			)}
			{type === 'danger' && (
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="9"></circle><path d="m5.6 5.6 12.8 12.8"></path>
				</svg>
			)}
			{type === 'ai' && (
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="m12 3 1.8 4.7L18 9.5l-4.2 1.8L12 16l-1.8-4.7L6 9.5l4.2-1.8Z"></path>
				</svg>
			)}
		</span>
		{title}
	</p>
	<section>
		<slot />
	</section>
</aside>
