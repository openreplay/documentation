---
let { videoURL, title, description } = Astro.props;

// videoURL may be a full URL (youtu.be/ID, watch?v=ID, embed/ID) or a bare 11-char ID.
function youtubeId(input) {
	if (!input) return null;
	const s = String(input).trim();
	if (/^[\w-]{11}$/.test(s)) return s;
	const m = s.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/)([\w-]{11})/);
	return m ? m[1] : null;
}

const id = youtubeId(videoURL);
const poster = id ? `https://i.ytimg.com/vi/${id}/hqdefault.jpg` : null;
const watch = id ? `https://www.youtube.com/watch?v=${id}` : videoURL;
const label = title ? `Watch on YouTube: ${title}` : 'Watch on YouTube';
---

<div class="or-video">
	<a
		class="or-video-thumb"
		href={watch}
		target="_blank"
		rel="noreferrer"
		aria-label={label}
		style={poster ? `background-image:url('${poster}')` : undefined}
	>
		<span class="or-video-play">
			<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg>
		</span>
	</a>
	<div class="or-video-body">
		<p class="or-video-eye">Video Tutorial</p>
		{title && <p class="or-video-t">{title}</p>}
		{description && <p class="or-video-d">{description}</p>}
	</div>
</div>
