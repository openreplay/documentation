---
// Video callout (design ".or-video"): ink→pink gradient thumbnail with a play
// overlay + eyebrow/title/description. The whole callout links to the video.
let { videoURL, title, description } = Astro.props;
---

<a class="or-video" href={videoURL} target="_blank" rel="noreferrer">
	<div class="or-video-thumb" aria-hidden="true">
		<span class="or-video-play">
			<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M7 4.5v15l12-7.5-12-7.5Z"></path></svg>
		</span>
	</div>
	<div class="or-video-body">
		<p class="or-video-eye">Video tutorial</p>
		{title && <p class="or-video-t">{title}</p>}
		{description && <p class="or-video-d">{description}</p>}
	</div>
</a>
