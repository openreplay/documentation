---
import languages from '../../i18n/languages';
import { useTranslations } from '../../i18n/util';
import SplashLayout from '../../layouts/SplashLayout.astro';

export const getStaticPaths = () => Object.keys(languages).map((lang) => ({ params: { lang } }));
const { lang = 'en' } = Astro.params;
const t = useTranslations(Astro);
---

<SplashLayout title={t('404.title')}>
	<div class="or-404">
		<div class="or-404-robot">
			<!-- Animated 404 robot — "The Yank": tugs its power cord, spark, lights out, recoil.
			     Colors map to the redesign tokens (accent) + a robot palette that flips for dark mode.
			     SVG can't read CSS vars from presentation attributes, so themed fills/strokes live in
			     each element's inline style. Keyframes are global (see <style is:global> below) because
			     Astro would otherwise rename them and break the inline `animation:` references. -->
			<svg viewBox="0 0 240 200" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<ellipse cx="118" cy="176" rx="56" ry="6.5" style="fill:var(--r-shadow); transform-box:fill-box; transform-origin:50% 50%; animation:r4_shadow calc(3.8s*var(--spd,1)) ease-in-out infinite;"></ellipse>
				<line x1="8" y1="176" x2="232" y2="176" stroke-width="2" style="stroke:var(--r-metal);"></line>
				<g>
					<rect x="206" y="146" width="24" height="30" rx="5" stroke-width="1.6" style="fill:var(--r-metal2); stroke:var(--r-ink);"></rect>
					<line x1="210" y1="156" x2="224" y2="156" stroke-width="2.4" style="stroke:var(--r-ink);"></line>
					<line x1="210" y1="164" x2="224" y2="164" stroke-width="2.4" style="stroke:var(--r-ink);"></line>
				</g>
				<g style="transform-box:fill-box; transform-origin:50% 100%; animation:r4_rock calc(3.8s*var(--spd,1)) ease-in-out infinite;">
					<g style="transform-box:fill-box; transform-origin:50% 100%; animation:r4_whip calc(3.8s*var(--spd,1)) ease-in-out infinite;">
						<path d="M120 49 C121 39 114 33 117 23 C119 15 128 14 131 6 C132 2 128 1 126 4 C123 9 125 17 120 27 C116 35 119 42 120 49 Z" stroke-width="1.7" style="fill:var(--r-paper); stroke:var(--r-ink);"></path>
					</g>
					<path d="M120 48 C96 48 82 64 82 92 C82 110 81 132 88 146 C95 160 108 166 120 166 C132 166 145 160 152 146 C159 132 158 110 158 92 C158 64 144 48 120 48 Z" stroke-width="1.8" style="fill:var(--r-paper); stroke:var(--r-ink);"></path>
					<path d="M86 72 C100 80 140 80 154 72" stroke-width="1.3" style="fill:none; stroke:var(--r-ink); opacity:0.7;"></path>
					<line x1="100" y1="66" x2="100" y2="74" stroke-width="1.3" style="stroke:var(--r-ink);"></line>
					<line x1="103" y1="65" x2="103" y2="74" stroke-width="1.3" style="stroke:var(--r-ink);"></line>
					<line x1="106" y1="66" x2="106" y2="73" stroke-width="1.3" style="stroke:var(--r-ink);"></line>
					<g>
						<path d="M86 104 C76 106 69 118 70 132 C71 142 75 148 80 147 C84 146 85 140 84 132 C83 120 84 112 90 108 Z" stroke-width="1.8" style="fill:var(--r-paper); stroke:var(--r-ink);"></path>
						<ellipse cx="74" cy="144" rx="7.5" ry="7.5" stroke-width="1.8" style="fill:var(--r-paper); stroke:var(--r-ink);"></ellipse>
					</g>
					<g style="transform-box:fill-box; transform-origin:50% 50%;">
						<rect x="92" y="80" width="56" height="26" rx="7" stroke-width="1.8" style="fill:var(--r-screen1); stroke:var(--r-ink);"></rect>
						<path d="M114 86 L132 93 L114 100 Z" style="fill:var(--accent);"></path>
						<rect x="92" y="80" width="56" height="26" rx="7" style="fill:var(--accent); mix-blend-mode:screen; animation:r4_glow calc(3.8s*var(--spd,1)) ease-in-out infinite;"></rect>
						<rect x="92" y="80" width="56" height="26" rx="7" style="fill:var(--r-screenoff); animation:r4_off calc(3.8s*var(--spd,1)) ease-in-out infinite;"></rect>
					</g>
					<g style="animation:r4_yank calc(3.8s*var(--spd,1)) cubic-bezier(.34,1.3,.5,1) infinite;">
						<path d="M154 100 C168 99 180 105 187 115 C190 120 186 124 181 121 C173 114 162 110 153 111 C149 111 149 102 154 100 Z" stroke-width="1.8" style="fill:var(--r-paper); stroke:var(--r-ink);"></path>
						<ellipse cx="185" cy="117" rx="7.5" ry="7.5" stroke-width="1.8" style="fill:var(--r-paper); stroke:var(--r-ink);"></ellipse>
						<path d="M184 123 C181 134 179 142 180 149" stroke-width="2.4" style="fill:none; stroke:var(--r-metal);"></path>
						<rect x="172" y="150" width="16" height="18" rx="3" stroke-width="1.6" style="fill:var(--r-metal2); stroke:var(--r-ink);"></rect>
						<line x1="188" y1="156" x2="198" y2="156" stroke-width="2.4" style="stroke:var(--r-ink);"></line>
						<line x1="188" y1="164" x2="198" y2="164" stroke-width="2.4" style="stroke:var(--r-ink);"></line>
					</g>
				</g>
				<g style="transform-box:fill-box; transform-origin:50% 50%; animation:r4_spark calc(3.8s*var(--spd,1)) ease-out infinite;">
					<line x1="206" y1="160" x2="199" y2="151" stroke-width="1.8" style="stroke:var(--accent);"></line>
					<line x1="206" y1="160" x2="215" y2="151" stroke-width="1.8" style="stroke:var(--accent);"></line>
					<line x1="206" y1="160" x2="196" y2="161" stroke-width="1.8" style="stroke:var(--accent);"></line>
					<line x1="206" y1="160" x2="206" y2="147" stroke-width="1.8" style="stroke:var(--accent);"></line>
					<line x1="206" y1="160" x2="201" y2="170" stroke-width="1.8" style="stroke:var(--accent);"></line>
					<line x1="206" y1="160" x2="214" y2="169" stroke-width="1.8" style="stroke:var(--accent);"></line>
					<circle cx="198" cy="150" r="1.5" style="fill:var(--accent);"></circle>
					<circle cx="215" cy="168" r="1.5" style="fill:var(--accent);"></circle>
					<circle cx="206" cy="160" r="2.6" style="fill:#FFFFFF;"></circle>
				</g>
			</svg>
		</div>

		<p class="or-404-eyebrow">404</p>
		<h1 class="or-404-title">{t('404.title')}</h1>
		<p class="or-404-desc">{t('404.content')}</p>
		<a class="or-404-btn" href={`/${lang}/`}>{t('404.linkText')}</a>
	</div>
</SplashLayout>

<style is:global>
	/* ---- Animated 404 robot ("The Yank") + page chrome ----
	   Everything is namespaced under .or-404 so nothing leaks. Keyframes are global
	   (not Astro-scoped) so the SVG's inline `animation:` references resolve. */

	/* "The Yank" loop (3.8s): the robot tugs its power cord, a spark pops at the
	   outlet, its screen flickers out, and it recoils — then recovers and repeats.
	   The arm group (r4_yank) has no transform-origin, so it only translates; the
	   body/antenna/spark/shadow groups set transform-box:fill-box inline and rotate
	   or scale about their own box. */
	@keyframes r4_yank {
		0%, 18%   { transform: translate(0, 0); }
		30%       { transform: translate(-10px, -4px); } /* pull the cord taut */
		40%       { transform: translate(4px, 2px); }    /* it pops loose */
		55%, 100% { transform: translate(0, 0); }
	}
	@keyframes r4_rock {
		0%, 22%   { transform: rotate(0deg); }
		32%       { transform: rotate(2.5deg); }   /* lean into the pull */
		42%       { transform: rotate(-4.5deg); }  /* recoil from the jolt */
		54%       { transform: rotate(2deg); }
		64%       { transform: rotate(-1deg); }
		74%, 100% { transform: rotate(0deg); }
	}
	@keyframes r4_whip {
		0%, 22%   { transform: rotate(0deg); }
		34%       { transform: rotate(12deg); }
		44%       { transform: rotate(-14deg); }   /* antenna snaps back */
		56%       { transform: rotate(7deg); }
		66%       { transform: rotate(-3deg); }
		76%, 100% { transform: rotate(0deg); }
	}
	@keyframes r4_spark {
		0%, 33%   { opacity: 0; transform: scale(0.4); }
		37%       { opacity: 1; transform: scale(1.15); } /* flash at the outlet */
		46%       { opacity: 0; transform: scale(0.6); }
		100%      { opacity: 0; }
	}
	@keyframes r4_glow {
		0%, 34%   { opacity: 0.85; }
		37%       { opacity: 0.25; }  /* flicker as power is cut */
		40%       { opacity: 0; }     /* lights out */
		82%       { opacity: 0; }
		90%       { opacity: 0.5; }   /* power restored */
		100%      { opacity: 0.85; }
	}
	@keyframes r4_off {
		0%, 38%   { opacity: 0; }
		41%       { opacity: 1; }     /* dark screen overlay shows */
		82%       { opacity: 1; }
		92%, 100% { opacity: 0; }     /* screen comes back on */
	}
	@keyframes r4_shadow {
		0%, 22%   { transform: scaleX(1); opacity: 1; }
		42%       { transform: scaleX(0.9); opacity: 0.78; } /* recoil lifts it slightly */
		64%       { transform: scaleX(1.03); opacity: 1; }
		74%, 100% { transform: scaleX(1); opacity: 1; }
	}

	.or-404 {
		text-align: center;
		max-width: 560px;
		margin-inline: auto;
		padding: 8px 0 16px;
	}
	.or-404-robot {
		width: clamp(190px, 54vw, 300px);
		margin: 0 auto 4px;
		--spd: 1;
		/* light palette (robot only; accent comes from the redesign token) */
		--r-paper: #ffffff;
		--r-ink: #2a2630;
		--r-metal: #a8a3ae;
		--r-metal2: #eceaf0;
		--r-screen1: #d6daff;
		--r-screenoff: #0d033b;
		--r-shadow: rgba(20, 10, 40, 0.13);
	}
	html.theme-dark .or-404-robot {
		--r-paper: #241a52;
		--r-ink: #eae7f6;
		--r-metal: #6e6890;
		--r-metal2: #352a63;
		--r-screen1: #2a2f8f;
		--r-screenoff: #050120;
		--r-shadow: rgba(0, 0, 0, 0.4);
	}
	.or-404-robot svg { width: 100%; height: auto; display: block; overflow: visible; }

	.or-404-eyebrow {
		font-family: var(--fb);
		font-weight: 700;
		font-size: 13px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 6px;
	}
	.or-404-title {
		font-family: var(--fd);
		font-weight: 700;
		font-size: clamp(28px, 5vw, 40px);
		line-height: 1.05;
		letter-spacing: -0.02em;
		color: var(--text);
		margin: 0 0 12px;
	}
	.or-404-desc {
		font-family: var(--fb);
		font-size: 16px;
		line-height: 1.5;
		color: var(--text-2);
		max-width: 42ch;
		margin: 0 auto 26px;
	}
	.or-404-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 44px;
		padding: 0 24px;
		border-radius: 9999px;
		background: var(--accent);
		color: #fff;
		font-family: var(--fb);
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.2s ease, box-shadow 0.2s ease;
	}
	.or-404-btn:hover { background: var(--accent-press); box-shadow: var(--shadow-md); color: #fff; }

	/* Desktop + tablet: the header's "Try Cloud" CTA is visible there (it's hidden
	   ≤768px via .hide-sm), so demote the 404 action to a plain accent text link so
	   it doesn't compete with that primary CTA. On mobile it stays a tappable pill. */
	@media (min-width: 769px) {
		.or-404-btn {
			height: auto;
			padding: 0;
			background: none;
			border-radius: 0;
			color: var(--accent);
			box-shadow: none;
		}
		.or-404-btn:hover {
			background: none;
			box-shadow: none;
			color: var(--accent-press);
			text-decoration: underline;
			text-underline-offset: 4px;
		}
	}

	/* Respect reduced-motion: hold the robot in its resting pose. */
	@media (prefers-reduced-motion: reduce) {
		.or-404-robot svg * { animation: none !important; }
	}
</style>

<script>
	window.addEventListener('load', () => window.fathom.trackGoal('4KN9VI2W', 0));
</script>
