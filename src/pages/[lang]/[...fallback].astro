---
import languages from '../../i18n/languages';
import { groupPagesByLang } from '../../util/groupPagesByLang';

export async function getStaticPaths() {
	const allPages = await Astro.glob('../**/*.mdx');
	const pagesByLang = groupPagesByLang(allPages);

	const paths = [];
	for (const { url } of pagesByLang.en) {
		const slug = url.slice(4);
		for (const lang of Object.keys(languages)) {
			if (lang === 'en') continue;
			const doesNotNeedFallback = pagesByLang[lang]?.some((p) => p.url.endsWith(slug));
			if (doesNotNeedFallback) continue;
			paths.push({ params: { lang, fallback: slug } });
		}
	}
	return paths;
}

// No translation exists for this page in the requested language. Rather than
// re-rendering the full English content under the localized URL (which produced
// ~9k duplicate pages and dominated build time), emit a lightweight client-side
// redirect to the English original. The URL still resolves; it just forwards.
const { fallback } = Astro.params;
const path = (fallback ?? '').replace(/\/$/, '');
const target = path ? `/en/${path}/` : '/en/';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta http-equiv="refresh" content={`0; url=${target}`} />
		<link rel="canonical" href={target} />
		<meta name="robots" content="noindex, follow" />
		<title>Redirecting to the English documentation…</title>
	</head>
	<body>
		<p>This page isn't translated yet. Redirecting to <a href={target}>the English version</a>.</p>
	</body>
</html>
